<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="rootPane" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.MovimientoInventarioController">
    <children>
        <Label text="Movimientos de Inventario">
            <font>
                <Font name="System Bold" size="22.0" />
            </font>
        </Label>

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <TextField fx:id="txtBuscar" promptText="Buscar por producto, tipo o usuario..." prefWidth="320.0" style="-fx-padding: 10;" />
                <DatePicker fx:id="dpFecha" promptText="Filtrar por fecha" />
                <Button mnemonicParsing="false" onAction="#limpiarFiltros" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-padding: 10 16;" text="Limpiar" />
            </children>
        </HBox>

        <TableView fx:id="tablaMovimientos" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" prefWidth="90.0" text="ID" />
                <TableColumn fx:id="colUsuario" prefWidth="130.0" text="Usuario" />
                <TableColumn fx:id="colFecha" prefWidth="110.0" text="Fecha" />
                <TableColumn fx:id="colHora" prefWidth="90.0" text="Hora" />
                <TableColumn fx:id="colTipo" prefWidth="160.0" text="Tipo" />
                <TableColumn fx:id="colProducto" prefWidth="110.0" text="ID Producto" />
                <TableColumn fx:id="colNombreProducto" prefWidth="180.0" text="Producto" />
                <TableColumn fx:id="colAnterior" prefWidth="90.0" text="Antes" />
                <TableColumn fx:id="colNueva" prefWidth="90.0" text="Después" />
                <TableColumn fx:id="colObservacion" prefWidth="180.0" text="Observación" />
            </columns>
        </TableView>
    </children>
</VBox>
