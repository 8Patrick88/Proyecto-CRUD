<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.InventarioController">
    <children>
        <Label text="Inventario">
            <font>
                <Font name="System Bold" size="22.0" />
            </font>
        </Label>

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <TextField fx:id="txtBuscarId" promptText="Buscar por ID, nombre o categoría..." prefWidth="280.0" style="-fx-padding: 8;" />
                <Button mnemonicParsing="false" onAction="#accionBuscar" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 8 15;" text="Buscar" />
                <Button mnemonicParsing="false" onAction="#accionRestaurar" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-padding: 8 15;" text="Mostrar Todos" />
            </children>
        </HBox>

        <TableView fx:id="tablaProductos" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" prefWidth="110.0" text="ID" />
                <TableColumn fx:id="colNombre" prefWidth="220.0" text="Nombre" />
                <TableColumn fx:id="colCategoria" prefWidth="140.0" text="Categoría" />
                <TableColumn fx:id="colPrecioVenta" prefWidth="120.0" text="Precio Venta" />
                <TableColumn fx:id="colStock" prefWidth="110.0" text="Stock Actual" />
                <TableColumn fx:id="colMinimo" prefWidth="110.0" text="Stock Mínimo" />
                <TableColumn fx:id="colEstado" prefWidth="140.0" text="Estado de alerta" />
            </columns>
        </TableView>

        <HBox alignment="CENTER_RIGHT">
            <children>
                <Button mnemonicParsing="false" onAction="#accionEliminar" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-padding: 10 20;" text="Eliminar Seleccionado">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
            </children>
        </HBox>
    </children>
</VBox>
