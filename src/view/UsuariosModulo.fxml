<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="rootPane" spacing="16.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.UsuarioController">
    <children>
        <Label text="Gestión de Usuarios">
            <font>
                <Font name="System Bold" size="22.0" />
            </font>
        </Label>

        <GridPane hgap="12.0" vgap="12.0">
            <children>
                <Label text="Nombre:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="txtNombre" promptText="Nombre completo" prefWidth="260.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Usuario:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="txtUsuario" promptText="Usuario de acceso" prefWidth="260.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Contraseña:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <TextField fx:id="txtContrasena" promptText="Contraseña" prefWidth="260.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="Rol:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                <ComboBox fx:id="cmbRol" prefWidth="180.0" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                <Label text="Estado:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                <ComboBox fx:id="cmbEstado" prefWidth="180.0" GridPane.columnIndex="3" GridPane.rowIndex="1" />
            </children>
        </GridPane>

        <HBox spacing="10.0">
            <children>
                <Button mnemonicParsing="false" onAction="#registrarUsuario" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-padding: 9 16;" text="Registrar" />
                <Button mnemonicParsing="false" onAction="#actualizarUsuario" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 9 16;" text="Actualizar" />
                <Button mnemonicParsing="false" onAction="#desactivarUsuario" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-padding: 9 16;" text="Desactivar" />
                <Button mnemonicParsing="false" onAction="#limpiarFormulario" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-padding: 9 16;" text="Limpiar" />
            </children>
        </HBox>

        <TableView fx:id="tablaUsuarios" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" prefWidth="90.0" text="ID" />
                <TableColumn fx:id="colNombre" prefWidth="220.0" text="Nombre" />
                <TableColumn fx:id="colUsuario" prefWidth="150.0" text="Usuario" />
                <TableColumn fx:id="colRol" prefWidth="120.0" text="Rol" />
                <TableColumn fx:id="colEstado" prefWidth="120.0" text="Estado" />
            </columns>
        </TableView>
    </children>
</VBox>
