<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="rootPane" alignment="CENTER" prefHeight="450.0" prefWidth="400.0" spacing="20.0" style="-fx-background-color: #2c3e50;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.LoginController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>
    <children>


        <Label text="Iniciar Sesión" textFill="white">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>

        <Label text="Sistema de Gestión de Inventario" textFill="#bdc3c7">
            <font>
                <Font size="14.0" />
            </font>
            <VBox.margin>
                <Insets bottom="10.0" />
            </VBox.margin>
        </Label>

        <VBox spacing="5.0" alignment="CENTER_LEFT">
            <children>
                <Label text="Usuario:" textFill="#ecf0f1" />
                <TextField fx:id="txtUsuario" prefHeight="35.0" promptText="Ingrese su usuario" style="-fx-background-radius: 5;" />
            </children>
        </VBox>

        <VBox spacing="5.0" alignment="CENTER_LEFT">
            <children>
                <Label text="Contraseña:" textFill="#ecf0f1" />
                <PasswordField fx:id="txtPassword" prefHeight="35.0" promptText="Ingrese su contraseña" style="-fx-background-radius: 5;" />
            </children>
        </VBox>

        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#accionIngresar" prefHeight="40.0" style="-fx-background-color: #2ecc71; -fx-background-radius: 5; -fx-cursor: hand;" text="Ingresar al Sistema" textFill="white">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </Button>

        <Label fx:id="lblError" text="Usuario o contraseña incorrectos" textFill="#e74c3c" visible="false" wrapText="true">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Label>

    </children>
</VBox>
